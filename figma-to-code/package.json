{
  "name": "@frontend/figma-to-code",
  "version": "0.7.1",
  "description": "Convert Figma designs to code using REST API with PAT authentication",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "figma-to-code": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    ".claude",
    "template",
    "tokens",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "eslint . --ext .ts,.mts,.cts,.js,.mjs,.cjs",
    "lint:fix": "eslint . --ext .ts,.mts,.cts,.js,.mjs,.cjs --fix",
    "format": "oxfmt --ignore-path ./.gitignore",
    "format:check": "oxfmt --ignore-path ./.gitignore --check",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "figma",
    "design-to-code",
    "rest-api",
    "code-generation"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "publishConfig": {
    "@frontend:registry": "https://g.echo.tech/api/v4/projects/1455/packages/npm/"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsdown": "^0.20.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "dependencies": {},
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
